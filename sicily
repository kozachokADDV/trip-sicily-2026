// Render hour labels
const hoursEl = document.getElementById('gantt-hours');
for (let h = H_START; h <= H_END; h++) {
  const tick = document.createElement('div');
  tick.className = 'absolute top-0 h-full border-l border-slate-200 text-[10px] pl-1';
  tick.style.left = pct(h) + '%';
  tick.textContent = String(h).padStart(2,'0');
  hoursEl.appendChild(tick);
}

// Render rows
const body = document.getElementById('gantt-body');
DAYS.forEach((day, idx) => {
  const row = document.createElement('div');
  row.className = 'flex border-b border-slate-200 ' + (idx % 2 ? 'bg-slate-50/50' : 'bg-white');

  const label = document.createElement('div');
  label.className = 'w-28 shrink-0 px-2 py-2 border-r border-slate-200';
  label.innerHTML = '<div class="text-xs font-bold text-slate-700">' + day.date + '</div><div class="text-[10px] text-slate-500 leading-tight">' + day.title + '</div>';
  row.appendChild(label);

  const track = document.createElement('div');
  track.className = 'flex-1 relative h-14';
  // hour grid lines
  for (let h = H_START + 1; h < H_END; h++) {
    const line = document.createElement('div');
    line.className = 'absolute top-0 bottom-0 border-l border-slate-100';
    line.style.left = pct(h) + '%';
    track.appendChild(line);
  }
  // bars
  day.items.forEach(it => {
    const bar = document.createElement('div');
    const color = COLORS[it.t] || 'bg-slate-300';
    bar.className = 'absolute top-2 h-10 rounded ' + color + ' text-white text-[9px] px-1 py-0.5 overflow-hidden cursor-help hover:ring-2 hover:ring-offset-1 hover:ring-slate-400 transition';
    bar.style.left = pct(it.s) + '%';
    bar.style.width = (pct(it.e) - pct(it.s)) + '%';
    bar.title = fmt(it.s) + '–' + fmt(it.e) + ' · ' + it.l;
    bar.textContent = it.l;
    track.appendChild(bar);
  });
  row.appendChild(track);
  body.appendChild(row);
});
